.merchant-product-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 0 120rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin: 0 24rpx 24rpx;
}

.category-card,
.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 0 24rpx 24rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 18rpx;
}

.category-create-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-input {
  flex: 1;
  height: 76rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.category-create-btn {
  width: 128rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: #d81e06;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  margin: 0;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;

  line-height: normal;
}

.category-create-btn::after {
  border: none;
}

.category-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 240rpx;
  min-height: 46rpx;
  padding: 8rpx 16rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
  color: #666666;
  font-size: 24rpx;
  box-sizing: border-box;
}

.category-chip-text {
  max-width: 170rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 30rpx;
}

.category-chip-arrow {
  font-size: 22rpx;
  color: #999999;
  margin-left: 8rpx;
  line-height: 30rpx;
}

.input {
  height: 78rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  color: #333333;
}

.form-label {
  font-size: 26rpx;
  color: #333333;
  margin: 18rpx 0 8rpx;
}

.new-product-category-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 12rpx 0 18rpx;
}

.new-product-category {
  padding: 8rpx 18rpx;
  border-radius: 22rpx;
  background: #f5f5f5;
  color: #666666;
  font-size: 24rpx;
}

.new-product-category-active {
  background: #fff2f0;
  color: #d81e06;
  font-weight: 700;
  border: 1rpx solid #d81e06;
}

.create-btn {
  margin-top: 10rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: #d81e06;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;

  line-height: normal;
}

.create-btn::after {
  border: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin: 8rpx 24rpx 18rpx;
}

.product-layout {
  display: flex;
  width: 100%;
  min-height: 680rpx;
  background: #f5f5f5;
}

.category-sidebar {
  width: 176rpx;
  background: #f7f7f7;
  min-height: 680rpx;
  border-right: 1rpx solid #eeeeee;
  flex-shrink: 0;
  box-sizing: border-box;
}

.category-item {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 25rpx;
  color: #555555;
  background: #f7f7f7;
  position: relative;
  box-sizing: border-box;
  padding: 0 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.active-category {
  background: #ffffff;
  color: #d81e06;
  font-weight: 700;
}

.active-category::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  width: 8rpx;
  height: 40rpx;
  background: #d81e06;
  border-radius: 0 8rpx 8rpx 0;
}

.product-area {
  flex: 1;
  padding: 20rpx 24rpx 20rpx 20rpx;
  box-sizing: border-box;
  min-width: 0;
}

.product-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.04);
}

.product-main {
  min-width: 0;
}

.product-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #222222;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-category {
  display: inline-block;
  font-size: 22rpx;
  color: #999999;
  background: #f7f7f7;
  border-radius: 18rpx;
  padding: 4rpx 14rpx;
  margin-bottom: 12rpx;
}

.product-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #d81e06;
}

.product-stock,
.product-variant-summary {
  font-size: 24rpx;
  color: #999999;
}

.enabled-tag,
.disabled-tag {
  flex-shrink: 0;
  margin-left: 12rpx;
  padding: 4rpx 14rpx;
  border-radius: 18rpx;
  font-size: 22rpx;
}

.enabled-tag {
  background: #e9f8ef;
  color: #1aad19;
}

.disabled-tag {
  background: #f1f1f1;
  color: #999999;
}

.product-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.edit-btn,
.online-btn,
.offline-btn {
  width: 120rpx;
  height: 56rpx;
  border-radius: 28rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  margin: 0;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;

  line-height: normal;
}

.edit-btn {
  background: #ff9f00;
}

.online-btn {
  background: #1aad19;
}

.offline-btn {
  background: #999999;
}

.edit-btn::after,
.online-btn::after,
.offline-btn::after {
  border: none;
}

.empty-category,
.empty-box {
  margin-top: 120rpx;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
}

.popup-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 998;
}

.action-popup {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  z-index: 999;
}

.action-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.action-category-name {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.action-item {
  height: 82rpx;
  line-height: 82rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333333;
  border-top: 1rpx solid #f0f0f0;
}

.danger-action {
  color: #d81e06;
}

.action-cancel {
  height: 82rpx;
  line-height: 82rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666666;
  background: #f5f5f5;
  border-radius: 41rpx;
  margin-top: 18rpx;
}

.rename-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  z-index: 999;
}

.rename-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.rename-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.rename-input {
  height: 82rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 28rpx;
}

.rename-actions {
  display: flex;
  gap: 18rpx;
}

.rename-cancel-btn,
.rename-confirm-btn {
  flex: 1;
  height: 82rpx;
  border-radius: 41rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin: 0;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;

  line-height: normal;
}

.rename-cancel-btn {
  background: #eeeeee;
  color: #666666;
}

.rename-confirm-btn {
  background: #d81e06;
  color: #ffffff;
}

.rename-cancel-btn::after,
.rename-confirm-btn::after {
  border: none;
}