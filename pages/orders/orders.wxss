.orders-page {
  min-height: 100vh;
  background-color: #f7f7f7;
  padding: 28rpx 28rpx 140rpx;
  box-sizing: border-box;
}

.empty-box {
  padding-top: 220rpx;
  text-align: center;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
}

.orders-title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 28rpx;
  color: #333333;
}

.order-card {
  background-color: #ffffff;
  border-radius: 22rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-sizing: border-box;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.order-id {
  font-size: 24rpx;
  color: #666666;
}

.order-status {
  color: #d81e06;
  font-size: 26rpx;
  font-weight: 700;
  background-color: #fff1eb;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
}

.order-meta {
  display: flex;
  justify-content: space-between;
  color: #999999;
  font-size: 24rpx;
  margin-bottom: 22rpx;
}

.product-list {
  border-top: 1rpx solid #eeeeee;
  border-bottom: 1rpx solid #eeeeee;
  padding: 18rpx 0;
}

.order-product {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.order-product:last-child {
  margin-bottom: 0;
}

.product-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.product-count {
  font-size: 28rpx;
  color: #666666;
}

.order-footer {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}

.order-total {
  font-size: 32rpx;
  font-weight: 700;
  color: #d81e06;
}