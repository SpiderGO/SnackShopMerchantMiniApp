.container {
  min-height: 100vh;
  background-color: #f7f7f7;
  padding: 28rpx 28rpx 140rpx;
  box-sizing: border-box;
}

/* 顶部门店卡片 */
.store-card {
  width: 100%;
  background: linear-gradient(135deg, #d81e06, #ef3b2d);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 44rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 20rpx rgba(216, 30, 6, 0.18);
}

.store-header {
  display: flex;
  align-items: center;
}

.store-logo {
  width: 130rpx;
  height: 130rpx;
  border-radius: 14rpx;
  margin-right: 26rpx;
  flex-shrink: 0;
}

.store-info {
  flex: 1;
}

.store-name {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.store-desc {
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
}

/* 推荐商品标题 */
.section-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-right: 16rpx;
}

.section-tag {
  background-color: #fff1c2;
  color: #d81e06;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 22rpx;
}

/* 商品卡片 */
.product-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 22rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-sizing: border-box;

  display: flex;
  justify-content: space-between;
  align-items: center;

  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04);
}

.product-left {
  flex: 1;
  min-width: 0;
}

.product-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 12rpx;
}

.product-category {
  color: #666666;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.product-stock {
  color: #999999;
  font-size: 24rpx;
}

.product-right {
  width: 170rpx;
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.price {
  color: #d81e06;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.add-btn {
  min-width: 120rpx;
  height: 58rpx;
  line-height: 58rpx;
  background: linear-gradient(90deg, #d81e06, #ef3b2d);
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 700;
  padding: 0 24rpx;
}

.add-btn::after {
  border: none;
}