<view class="merchant-page">
  <view class="page-title">商家订单管理</view>

  <view wx:if="{{orders.length === 0}}" class="empty-box">
    <view class="empty-title">暂无订单</view>
    <view class="empty-desc">用户提交订单后会显示在这里</view>
  </view>

  <view wx:else>
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <view class="order-header">
        <view>
          <view class="order-id">订单号：{{item.id}}</view>
          <view class="order-time">{{item.createdAt}}</view>
        </view>

        <view class="status">{{item.status}}</view>
      </view>

      <view class="pickup-type">{{item.pickupType}}</view>

      <view class="product-list">
        <view
          class="product-row"
          wx:for="{{item.items}}"
          wx:for-item="product"
          wx:key="id"
        >
          <view class="product-name">{{product.name}}</view>
          <view class="product-quantity">× {{product.quantity}}</view>
        </view>
      </view>

      <view class="order-bottom">
        <view class="total">合计：￥{{item.totalAmount}}</view>
      </view>

      <view class="action-row">
        <button
          wx:if="{{item.status === '待商家确认'}}"
          class="accept-btn"
          size="mini"
          data-id="{{item.id}}"
          bindtap="acceptOrder"
        >
          接单
        </button>

        <button
          wx:if="{{item.status === '已接单'}}"
          class="complete-btn"
          size="mini"
          data-id="{{item.id}}"
          bindtap="completeOrder"
        >
          完成订单
        </button>

        <view wx:if="{{item.status === '已完成'}}" class="done-text">
          订单已完成
        </view>
      </view>
    </view>
  </view>
</view>