.mine-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #ff3b30, #d81e06);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(216, 30, 6, 0.15);
}

.avatar-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #ffffff;
  color: #d81e06;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.panel {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 40rpx;
}

.panel-item {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
}

.panel-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #333333;
}

.value {
  font-size: 26rpx;
  color: #999999;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #d81e06;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.logout-btn::after {
  border: none;
}