.login-page {
  min-height: 100vh;
  background-color: #f7f7f7;
  padding: 60rpx 28rpx;
  box-sizing: border-box;
}

.login-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 46rpx 32rpx;
  box-sizing: border-box;
  text-align: center;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.04);
}

.logo {
  width: 130rpx;
  height: 130rpx;
  border-radius: 16rpx;
  margin-bottom: 26rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 42rpx;
}

.input {
  height: 82rpx;
  background-color: #f7f7f7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  margin-bottom: 22rpx;
  text-align: left;
  font-size: 28rpx;
}

.login-btn {
  margin-top: 20rpx;
  height: 78rpx;
  border-radius: 39rpx;
  background: linear-gradient(90deg, #d81e06, #ef3b2d);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;

  display: flex;
  align-items: center;
  justify-content: center;

  padding: 0;
  line-height: normal;
}

.login-btn::after {
  border: none;
}